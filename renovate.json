{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "helpers:pinGitHubActionDigests"
  ],
  "schedule": ["* * 1,15 * *"],
  "prHourlyLimit": 0,
  "prConcurrentLimit": 0,
  "dependencyDashboard": true,
  "constraints": {
    "elixir": "1.20.2",
    "erlang": "28.5.0.3"
  },
  "pip_requirements": {
    "managerFilePatterns": ["/(^|/)ci-base\\.requirements\\.txt$/"]
  },
  "packageRules": [
    {
      "matchManagers": ["github-actions"],
      "groupName": "GitHub Actions"
    }
  ]
}
